#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'
set -vx

test -f gemset.nix -a -f Gemfile.lock && exit 0

nix run nixpkgs#bundler -- lock
nix run github:inscapist/bundix

# Although this is a library repo and Gemfile.lock is not normally
# source-controlled, Nix (bundix + flakes CI) requires both the lockfile
# and generated gemset to be present in the index for reproducible builds.
# Stage them automatically when generated.
git add    gemset.nix
git add -f Gemfile.lock
